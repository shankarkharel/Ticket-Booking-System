generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum BookingStatus {
  PENDING
  CONFIRMED
  FAILED
}

enum SeatStatus {
  AVAILABLE
  HELD
  BOOKED
}

model TicketTier {
  id                Int           @id @default(autoincrement())
  name              String        @unique
  price             Int
  totalQuantity     Int           @map("total_quantity")
  remainingQuantity Int           @map("remaining_quantity")
  bookingItems      BookingItem[]
  seats             TicketSeat[]

  @@map("ticket_tiers")
}

model Booking {
  id              Int           @id @default(autoincrement())
  bookingReference String       @unique @map("booking_reference")
  customerName    String        @map("customer_name")
  customerEmail   String        @map("customer_email")
  status          BookingStatus
  holdToken       String        @unique @map("hold_token")
  idempotencyKey  String        @unique @map("idempotency_key")
  createdAt       DateTime      @default(now()) @map("created_at")
  items           BookingItem[]
  seats           TicketSeat[]

  @@map("bookings")
}

model BookingItem {
  bookingId Int
  tierId    Int
  quantity  Int
  unitPrice Int @map("unit_price")

  booking Booking   @relation(fields: [bookingId], references: [id])
  tier    TicketTier @relation(fields: [tierId], references: [id])

  @@id([bookingId, tierId])
  @@map("booking_items")
}

model TicketSeat {
  id        Int        @id @default(autoincrement())
  tierId    Int        @map("tier_id")
  row       String
  number    Int
  label     String
  status    SeatStatus @default(AVAILABLE)
  bookingId Int?       @map("booking_id")
  holdToken String?    @map("hold_token")
  holdExpiresAt DateTime? @map("hold_expires_at")
  createdAt DateTime   @default(now()) @map("created_at")
  updatedAt DateTime   @updatedAt @map("updated_at")

  tier    TicketTier @relation(fields: [tierId], references: [id])
  booking Booking?   @relation(fields: [bookingId], references: [id])

  @@unique([tierId, row, number])
  @@index([tierId, status])
  @@index([holdToken])
  @@map("ticket_seats")
}
